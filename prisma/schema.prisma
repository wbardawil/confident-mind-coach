generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ──────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId   String?  @unique
  subscriptionTier   String   @default("free") // free | pro | elite
  subscriptionId     String?  // Stripe subscription ID
  subscriptionStatus String?  // active | canceled | past_due | trialing

  profile          Profile?
  documents        UserDocument[]
  achievements     Achievement[]
  goals            ConfidenceGoal[]
  affirmations     Affirmation[]
  events           Event[]
  espEntries       ESPEntry[]
  iprEntries       IPREntry[]
  aarEntries       AAREntry[]
  ledgerEntries    LedgerEntry[]
  coachingSessions CoachingSession[]
  chatSessions     ChatSession[]
  enrollments      ChallengeEnrollment[]
  journalEntries           CoachingJournal[]
  personalityAssessments   PersonalityAssessment[]
  visionDomains            VisionDomain[]
}

// ─── USER DOCUMENT (uploaded context files) ────

model UserDocument {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName         String
  fileType         String // pdf | docx | md | txt
  fileSize         Int // bytes
  category         String // resume | personality | assessment | notes | other
  extractedContent String // text extracted from the uploaded file
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── PROFILE (onboarding data) ─────────────────

model Profile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                 String
  performanceDomain    String
  strengths            String[]
  confidenceChallenges String[]
  recurringTriggers    String[]
  baselineScore        Int // 1–10
  coachModel           String   @default("haiku-4.5") // haiku-4.5 | sonnet-3.5 | sonnet-4 | opus-3
  timezone             String   @default("UTC") // IANA timezone e.g. "America/Mexico_City"
  language             String   @default("English") // coaching response language
  welcomeCompleted     Boolean  @default(false) // post-onboarding emotional check-in done
  onboardingCompleted  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─── PERSONALITY ASSESSMENT (structured personality data) ──

model PersonalityAssessment {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId   String?  // link to source UserDocument (null if manually entered)
  framework    String   // DISC | MBTI | EA | StrengthsFinder | VIA | Enneagram | Big5 | other
  label        String   // display name e.g. "DISC Assessment (2024)"
  dimensions   Json     // structured scores: { "D": 85, "I": 42, "S": 60, "C": 30 } etc.
  summary      String   // AI-generated plain-English summary
  coachingTips String   // AI-generated coaching implications
  verified     Boolean  @default(false) // user has reviewed and confirmed accuracy
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── VISION DOMAIN (10x life vision) ─────────────

model VisionDomain {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain       String   // career | financial | personal | health | relationship | other
  vision       String   // the 10x vision description
  currentState String?  // where they are now
  gap          String?  // AI-generated gap analysis
  priority     Int      @default(0) // ordering — first domain added = highest priority
  status       String   @default("active") // active | paused
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, domain])
}

// ─── ACHIEVEMENT (Top Ten confidence memories) ──

model Achievement {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  evidence    String // concrete proof / details
  occurredAt  DateTime? // when it happened (nullable)
  rank        Int? // optional ordering 1–10
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── CONFIDENCE GOAL (goal-directed confidence) ──

model ConfidenceGoal {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String // "Grow cash flow to $15K/month"
  description     String? // why this goal matters
  category        String // career | financial | personal | health | relationship | other
  targetDate      DateTime? // optional deadline
  efficacyScore   Int      @default(5) // 1-10: "How confident am I that I can achieve this?"
  status          String   @default("active") // active | achieved | paused
  evidenceCount   Int      @default(0) // cached count of linked ledger deposits
  visionDomainId  String?  // optional link to VisionDomain
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── AFFIRMATION ───────────────────────────────

model Affirmation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String // the affirmation content
  source    String // which workflow produced it (ESP, PREGAME, etc.)
  sourceId  String? // optional link to originating entry
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── EVENT ─────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  eventDate   DateTime?
  status      String    @default("upcoming") // upcoming | completed | cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── ESP ENTRY (Daily Effort / Success / Progress) ─

model ESPEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  effort    String
  success   String
  progress  String
  createdAt DateTime @default(now())
}

// ─── IPR ENTRY (Immediate Progress Review) ─────

model IPREntry {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskName       String
  whatWentWell   String
  repeatNextTime String
  createdAt      DateTime @default(now())
}

// ─── AAR ENTRY (After Action Review) ───────────

model AAREntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatHappened String
  soWhat      String
  nowWhat     String
  createdAt   DateTime @default(now())
}

// ─── COACHING SESSION (all AI interactions) ────

model CoachingSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode       String // ESP | PREGAME | RESET | AAR
  inputJson  Json // structured input sent to AI
  outputJson Json? // structured AI response (null if flagged)
  flagged    Boolean  @default(false)
  reason     String? // why it was flagged (null if safe)
  createdAt  DateTime @default(now())
}

// ─── CHAT SESSION (conversational coaching) ─────

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id            String      @id @default(cuid())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role          String // "user" | "assistant"
  content       String
  flagged       Boolean     @default(false)
  flaggedReason String?
  createdAt     DateTime    @default(now())
}

// ─── LEDGER ENTRY (confidence accounting) ──────

model LedgerEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // DEPOSIT | WITHDRAWAL | ADJUSTMENT
  title       String
  description String?
  scoreDelta  Int? // nullable point change
  sourceId    String? // nullable FK to originating record
  sourceType  String? // nullable: ESP | PREGAME | RESET | AAR | TOP_TEN | MANUAL
  goalId      String? // optional link to a ConfidenceGoal
  createdAt   DateTime @default(now())
}

// ─── CHALLENGE (time-boxed confidence programs) ──

model ChallengeEnrollment {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeSlug String // e.g. "imposter-syndrome-7d"
  currentDay    Int                 @default(1)
  status        String              @default("active") // active | completed | abandoned
  startedAt     DateTime            @default(now())
  completedAt   DateTime?
  dayEntries    ChallengeDayEntry[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([userId, challengeSlug])
}

model ChallengeDayEntry {
  id           String              @id @default(cuid())
  enrollmentId String
  enrollment   ChallengeEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  day          Int // 1-indexed day number
  reflection   String // user's response to the day's prompt
  aiResponse   String? // AI coaching for this day
  completedAt  DateTime            @default(now())
  createdAt    DateTime            @default(now())
}

// ─── COACHING JOURNAL (AI-authored coaching notes) ──

model CoachingJournal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // session | esp | reset | pregame | aar | challenge | weekly | monthly | quarterly
  sourceId  String? // optional link to originating session/entry
  content   String // AI-written coaching note
  period    String? // for syntheses: "2026-W14", "2026-03", "2026-Q1"
  createdAt DateTime @default(now())
}
